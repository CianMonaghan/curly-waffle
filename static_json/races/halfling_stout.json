{
    "type": "race",
    "id": 7,
    "name": "Stout Halfling",
    "description": "As a stout halfling, you're hardier than average and have some resistance to poison. Some say that stouts have dwarven blood. In the Forgotten Realms, these halflings are called stronghearts, and they're most common in the south.",

    "features": [
        {
            "id": "halfling-asi-dex-2",
            "feature_name": "Ability Score Increase (DEX +2)",
            "description": "Your Dexterity score increases by 2.",
            "feature_type": "passive",
            "trigger": "onAdd"
        },
        {
            "id": "speed-25-halfling",
            "feature_name": "Speed",
            "description": "Your base walking speed is 25 feet.",
            "feature_type": "passive",
            "trigger": "onAdd"
        },
        {
            "id": "halfling-lucky",
            "feature_name": "Lucky",
            "description": "When you roll a 1 on the d20 for an attack roll, ability check, or saving throw, you can reroll the die and must use the new roll.",
            "feature_type": "passive",
            "trigger": "onAdd"
        },
        {
            "id": "halfling-brave",
            "feature_name": "Brave",
            "description": "You have advantage on saving throws against being frightened.",
            "feature_type": "passive",
            "trigger": "onAdd"
        },
        {
            "id": "halfling-nimbleness",
            "feature_name": "Halfling Nimbleness",
            "description": "You can move through the space of any creature that is of a size larger than yours.",
            "feature_type": "passive",
            "trigger": "onAdd"
        },
        {
            "id": "halfling-lang",
            "feature_name": "Languages",
            "description": "You can speak, read, and write Common and Halfling.",
            "feature_type": "passive",
            "subtype": "prof_addition",
            "prof_to_add": [
                { "lang_prof": ["Common", "Halfling"] }
            ],
            "trigger": "onAdd"
        },
        {
            "id": "stout-asi-con-1",
            "feature_name": "Ability Score Increase (CON +1)",
            "description": "Your Constitution score increases by 1.",
            "feature_type": "passive",
            "trigger": "onAdd"
        },
        {
            "id": "stout-resilience",
            "feature_name": "Stout Resilience",
            "description": "You have advantage on saving throws against poison, and you have resistance against poison damage.",
            "feature_type": "passive",
            "trigger": "onAdd"
        }
    ]
}
